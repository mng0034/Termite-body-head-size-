library(tidyr)
#Plots
plot_data <- result %>%
pivot_longer(
cols = starts_with("sd_"),
names_to = c("sex", "trait"),
names_sep = "_",
values_to = "sd"
)
library(ggplot2)
#Plots
long_df <- df %>%
pivot_longer(
cols = c(f_head, f_body, m_head, m_body),
names_to = c("sex", "trait"),
names_sep = "_",
values_to = "value"
)
ggplot(long_df, aes(x = Species, y = value, fill = sex)) +
geom_boxplot() +
facet_wrap(~trait) +
theme_minimal()
