labs(
title = "Variation in Head and Body Size",
x = "Development Type",
y = "Measurement"
) +
theme_minimal()
result <- termite_data %>%
group_by(Species, Development) %>%
summarise(
sd_f_head = sd(f_head, na.rm = TRUE),
sd_m_head = sd(m_head, na.rm = TRUE),
sd_f_body = sd(f_body, na.rm = TRUE),
sd_m_body = sd(m_body, na.rm = TRUE),
.groups = "drop"
)
# view by species
print(result)
i
result_long <- result %>%
pivot_longer(
cols = c(sd_f_head, sd_m_head, sd_f_body, sd_m_body),
names_to = "measure",
values_to = "sd"
) %>%
separate(measure, into = c("sd", "sex", "trait"), sep = "_") %>%
select(-sd)
# view by species
print(result)
#Plots
ggplot(result_long, aes(x = Development, y = sd, fill = Development)) +
geom_boxplot(alpha = 0.7) +
geom_jitter(width = 0.1, size = 2) +
facet_grid(sex ~ trait) +
theme_classic() +
labs(
x = "Developmental type",
y = "Within-species SD",
title = "Variation in body and head size across developmental strategies"
)
