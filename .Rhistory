geom_col(position = "dodge") +
facet_wrap(~trait) +
theme_classic() +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
labs(
x = "Species",
y = "Standard deviation",
fill = "Sex",
title = "Male vs Female variation across species"
)
